# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=info
APP_SECRET_KEY=change-me-in-production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://aperture:aperture@localhost:5432/aperture?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./configs/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./configs/keys/jwt_public.pem
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# ─── Agent Service URLs ───────────────────────────────────────────────────────
AGENT_INTENT_URL=http://localhost:8101
AGENT_QUALIFY_URL=http://localhost:8102
AGENT_PERSONALISE_URL=http://localhost:8103
AGENT_CONVERSATION_URL=http://localhost:8104
AGENT_DOCUMENT_URL=http://localhost:8105
AGENT_COMPLIANCE_URL=http://localhost:8106
AGENT_EXPLAIN_URL=http://localhost:8107
AGENT_AUDIT_URL=http://localhost:8108
AGENT_TIMEOUT_SECONDS=30

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=aperture-backend
KAFKA_USE_MOCK=true

# ─── Object Storage (MinIO / S3) ─────────────────────────────────────────────
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_DOCUMENTS=aperture-documents
STORAGE_USE_SSL=false

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ─── Mock Integrations (set to false in production with real keys) ───────────
MOCK_NSDL_PAN=true
MOCK_CKYCR=true
MOCK_UIDAI=true
MOCK_AA=true
MOCK_DIGILOCKER=true
MOCK_SBI_CBS=true

# ─── Frontend (Next.js — NEXT_PUBLIC_ prefix exposed to browser) ─────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_AGENT_GATEWAY_URL=http://localhost:8100
NEXT_PUBLIC_APP_NAME=Aperture
NEXT_PUBLIC_ENV=development
